# Database (Railway Postgres)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Session Secret (generate: openssl rand -base64 32)
NEXTAUTH_SECRET=generate-a-random-secret-here

# Microsoft Graph (Azure AD App Registration)
# Single OAuth flow for both authentication AND mail access
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret
MICROSOFT_TENANT_ID=your-azure-tenant-id
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Restrict login to specific Microsoft email(s), comma-separated
# Leave empty to allow any Microsoft account
ALLOWED_EMAILS=your-email@yourdomain.com

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# App
APP_URL=http://localhost:3000
NODE_ENV=development
